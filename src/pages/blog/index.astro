---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const today = new Date();
today.setHours(23, 59, 59, 999);

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => new Date(post.data.date) <= today)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<Base
  title="Tous les comparatifs — Outils de fidélisation et avis Google"
  description="Tous nos comparatifs indépendants : Grow Lot vs Riwil, HeyPongo, Up Review, Basilyk, RushUp et plus. Choisissez le meilleur outil pour votre commerce."
>
  <main>
    <div class="section-title" style="margin-top:0">
      <h2>Tous les comparatifs</h2>
      <div class="section-title-line"></div>
      <span class="section-count">{posts.length} articles</span>
    </div>
    <div class="posts-grid">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="post-card">
          <div class="post-card-top">
            <span class="badge">Comparatif</span>
            <span class="post-date">{new Date(post.data.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          </div>
          <h2>{post.data.title}</h2>
          <p class="excerpt">{post.data.description}</p>
          <div class="post-card-footer">
            <span class="read-link">Lire le comparatif →</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</Base>
