---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const now = new Date();
const posts = await getCollection('blog');
const sorted = posts
  .filter(p => new Date(p.data.date) <= now)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Base
  title="Tous les comparatifs — Fidélisation & avis Google"
  description="Tous les articles comparatifs de kdokdo sur les logiciels de fidélisation gamifiée et de collecte d'avis Google pour commerces physiques."
>
  <h1>Tous les comparatifs</h1>
  <p style="color: #666; margin: 0.5rem 0 2rem;">{sorted.length} article{sorted.length > 1 ? 's' : ''} publié{sorted.length > 1 ? 's' : ''}</p>

  <div class="articles-grid">
    {sorted.map(post => (
      <div class="article-card">
        <a href={`/blog/${post.slug}/`}>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          <div class="card-meta">
            {new Date(post.data.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
            {post.data.tags?.map((tag: string) => (
              <span class="tag" style="margin-left: 0.4rem;">{tag}</span>
            ))}
          </div>
        </a>
      </div>
    ))}
  </div>
</Base>
