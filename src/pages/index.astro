---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);
---
<Base title="Comparatifs logiciels de fidélisation et avis Google" description="Comparatifs indépendants des meilleurs outils de fidélisation client et de collecte d'avis Google pour commerces physiques.">
  <h1>Quel outil de fidélisation choisir ?</h1>
  <p style="color: #666; margin: 1rem 0 2rem;">Comparatifs indépendants des logiciels de fidélisation, collecte d'avis Google et marketing local pour commerces physiques.</p>

  <div class="articles-grid">
    {posts.map(post => (
      <div class="article-card">
        <a href={`/blog/${post.slug}`}>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          <p style="color: #aaa; font-size: 0.8rem; margin-top: 0.5rem;">{new Date(post.data.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
        </a>
      </div>
    ))}
  </div>
</Base>
