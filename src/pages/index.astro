---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const today = new Date();
today.setHours(23, 59, 59, 999);

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => new Date(post.data.date) <= today)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<Base
  title="Comparatifs indépendants — Fidélisation & avis Google pour commerces"
  description="Comparatifs honnêtes et détaillés des outils de fidélisation et d'avis Google pour commerçants et restaurateurs. Grow Lot, Riwil, HeyPongo, Up Review et plus."
>
  <div class="hero">
    <span class="hero-eyebrow">✦ Comparatifs indépendants</span>
    <h1>Choisissez le meilleur outil de<br/><em>fidélisation</em> pour votre commerce</h1>
    <p>Analyses honnêtes et détaillées pour aider les commerçants à choisir sans se tromper.</p>
    <div class="hero-badges">
      <span class="hero-badge">✓ 100% indépendant</span>
      <span class="hero-badge">✓ Rédigé par des humains</span>
      <span class="hero-badge">✓ Mis à jour en 2026</span>
    </div>
  </div>

  <main>
    <div class="section-title">
      <h2>Tous les comparatifs</h2>
      <div class="section-title-line"></div>
      <span class="section-count">{posts.length} articles</span>
    </div>

    <div class="posts-grid">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="post-card">
          <div class="post-card-top">
            <span class="badge">Comparatif</span>
            <span class="post-date">{new Date(post.data.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          </div>
          <h2>{post.data.title}</h2>
          <p class="excerpt">{post.data.description}</p>
          <div class="post-card-footer">
            <span class="read-link">Lire le comparatif →</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</Base>
