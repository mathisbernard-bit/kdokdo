---
const { title, description, date, slug, type = 'website', author = 'Thomas Remy' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = 'https://kdokdo.com/og-default.png';
const siteName = 'kdokdo';

const articleSchema = type === 'article' ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date,
  "dateModified": date,
  "author": { "@type": "Person", "name": "Thomas Remy", "url": "https://kdokdo.com/a-propos" },
  "publisher": {
    "@type": "Organization", "name": "kdokdo", "url": "https://kdokdo.com",
    "logo": { "@type": "ImageObject", "url": ogImage }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalURL.toString() },
  "image": ogImage,
  "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".article-header h1", ".content > p:first-of-type"] }
}) : null;

const websiteSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteName,
  "url": "https://kdokdo.com",
  "description": "Comparatifs indépendants de logiciels de fidélisation et d'avis Google pour commerces physiques."
});
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | kdokdo</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content="index, follow" />
  <meta name="revisit-after" content="7 days" />
  <meta name="language" content="fr" />
  <meta name="geo.region" content="FR" />
  <meta name="geo.placename" content="France" />
  <meta name="ai-content-declaration" content="human-written" />
  <meta name="author" content="Thomas Remy" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#16a34a" />
  <meta property="og:title" content={`${title} | kdokdo`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="fr_FR" />
  {type === 'article' && date && <meta property="article:published_time" content={new Date(date).toISOString()} />}
  {type === 'article' && <meta property="article:author" content="Thomas Remy" />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | kdokdo`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Sora:wght@600;700;800&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={websiteSchema} />
  {articleSchema && <script type="application/ld+json" set:html={articleSchema} />}

  <style is:global>
    /* ── TOKENS ─────────────────────────────────────────────────────────────── */
    :root {
      --green:        #16a34a;
      --green-dark:   #15803d;
      --green-light:  #dcfce7;
      --green-pale:   #f0fdf4;
      --dark:         #0f172a;
      --dark-mid:     #1e293b;
      --gray:         #64748b;
      --gray-light:   #f1f5f9;
      --border:       #e2e8f0;
      --white:        #ffffff;
      --radius-sm:    6px;
      --radius-md:    12px;
      --radius-lg:    20px;
      --shadow-sm:    0 1px 4px rgba(0,0,0,.06);
      --shadow-md:    0 4px 20px rgba(0,0,0,.09);
      --shadow-green: 0 8px 28px rgba(22,163,74,.18);
      --max-w:        820px;
      --font:         'Inter', system-ui, sans-serif;
      --font-display: 'Sora', system-ui, sans-serif;
    }

    /* ── RESET ───────────────────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { height: 100%; scroll-behavior: smooth; }

    body {
      font-family: var(--font);
      font-size: 1rem;
      line-height: 1.75;
      color: var(--dark);
      background: var(--white);
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    h1, h2, h3, h4 {
      font-family: var(--font-display);
      line-height: 1.2;
      color: var(--dark);
    }

    a { color: var(--green); text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { max-width: 100%; display: block; }

    /* ── HEADER ──────────────────────────────────────────────────────────────── */
    .site-header {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      padding: 0 5%;
      height: 60px;
      display: flex;
      align-items: center;
      gap: 2rem;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: var(--shadow-sm);
    }

    .logo {
      font-family: var(--font-display);
      font-size: 1.2rem;
      font-weight: 800;
      color: var(--dark);
      letter-spacing: -0.03em;
      text-decoration: none !important;
      flex-shrink: 0;
    }
    .logo em { font-style: normal; color: var(--green); }

    .header-nav {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    .header-nav a {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--gray);
      padding: 0.4rem 0.75rem;
      border-radius: var(--radius-sm);
      transition: color .15s, background .15s;
      text-decoration: none !important;
    }
    .header-nav a:hover { color: var(--green); background: var(--green-pale); }

    .header-nav .btn-header {
      background: var(--green);
      color: var(--white) !important;
      font-weight: 600;
      margin-left: 0.5rem;
      padding: 0.4rem 1rem;
    }
    .header-nav .btn-header:hover { background: var(--green-dark); }

    /* ── PAGE WRAP ───────────────────────────────────────────────────────────── */
    .page-wrap { flex: 1; display: flex; flex-direction: column; }

    /* ── HERO HOMEPAGE ───────────────────────────────────────────────────────── */
    .hero {
      background: linear-gradient(135deg, var(--dark) 0%, var(--dark-mid) 100%);
      padding: 5rem 5% 4rem;
      text-align: center;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: rgba(22,163,74,.15);
      color: #4ade80;
      font-size: 0.78rem;
      font-weight: 600;
      padding: 0.3rem 0.9rem;
      border-radius: 20px;
      border: 1px solid rgba(74,222,128,.2);
      margin-bottom: 1.25rem;
      font-family: var(--font-display);
      letter-spacing: .04em;
    }

    .hero h1 {
      font-size: clamp(1.9rem, 4.5vw, 2.9rem);
      font-weight: 800;
      color: var(--white);
      margin-bottom: 1rem;
      letter-spacing: -0.03em;
    }

    .hero h1 em {
      font-style: normal;
      background: linear-gradient(90deg, #4ade80, #16a34a);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero p {
      color: rgba(255,255,255,.65);
      font-size: 1.05rem;
      max-width: 500px;
      margin: 0 auto 1.75rem;
    }

    .hero-badges {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.65rem;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      background: rgba(255,255,255,.07);
      color: rgba(255,255,255,.7);
      font-size: 0.78rem;
      padding: 0.3rem 0.85rem;
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,.1);
    }

    /* ── MAIN ────────────────────────────────────────────────────────────────── */
    main {
      flex: 1;
      width: 100%;
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 3.5rem 5% 5rem;
    }

    /* ── SECTION TITLE (homepage) ────────────────────────────────────────────── */
    .section-title {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.5rem;
    }
    .section-title h2 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--dark);
    }
    .section-title-line {
      flex: 1;
      height: 1px;
      background: var(--border);
    }
    .section-count {
      font-size: 0.78rem;
      color: var(--gray);
      font-weight: 500;
    }

    /* ── POST CARDS ──────────────────────────────────────────────────────────── */
    .posts-grid { display: grid; gap: 1rem; }

    .post-card {
      display: block;
      color: inherit;
      background: var(--white);
      border: 1.5px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 1.6rem 1.75rem;
      transition: border-color .2s, box-shadow .2s, transform .2s;
      text-decoration: none !important;
    }
    .post-card:hover {
      border-color: var(--green);
      box-shadow: var(--shadow-green);
      transform: translateY(-2px);
    }

    .post-card-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.6rem;
    }

    .badge {
      display: inline-block;
      background: var(--green-light);
      color: var(--green-dark);
      font-size: 0.68rem;
      font-weight: 700;
      font-family: var(--font-display);
      padding: 0.2rem 0.65rem;
      border-radius: 20px;
      text-transform: uppercase;
      letter-spacing: .07em;
    }

    .post-card h2 {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 0.4rem;
      line-height: 1.3;
    }

    .post-card .excerpt {
      color: var(--gray);
      font-size: 0.875rem;
      line-height: 1.6;
      margin-bottom: 1rem;
    }

    .post-card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .read-link {
      font-family: var(--font-display);
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--green);
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }

    .post-date {
      font-size: 0.74rem;
      color: #94a3b8;
    }

    /* ── ARTICLE PAGE ────────────────────────────────────────────────────────── */
    .article-header {
      margin-bottom: 2.5rem;
      padding-bottom: 2rem;
      border-bottom: 1.5px solid var(--border);
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.4rem;
      font-size: 0.78rem;
      color: #94a3b8;
      margin-bottom: 1.25rem;
    }
    .breadcrumb a { color: var(--green); }
    .breadcrumb a:hover { text-decoration: underline; }
    .breadcrumb-sep { color: #cbd5e1; }

    .article-header h1 {
      font-size: clamp(1.5rem, 3.5vw, 2rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      margin: 0.75rem 0;
      line-height: 1.2;
    }

    .article-meta {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem;
      font-size: 0.8rem;
      color: #94a3b8;
      margin-top: 0.5rem;
    }

    .trust-bar {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin: 1.25rem 0;
      padding: 0.85rem 1.2rem;
      background: var(--green-pale);
      border: 1px solid #bbf7d0;
      border-radius: var(--radius-md);
      font-size: 0.8rem;
      color: var(--green-dark);
      font-weight: 500;
    }
    .trust-bar span { display: flex; align-items: center; gap: 0.35rem; }

    /* ── CONTENT ─────────────────────────────────────────────────────────────── */
    .content h2 {
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--dark);
      margin: 2.75rem 0 0.75rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid var(--green-light);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .content h3 {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--dark-mid);
      margin: 1.75rem 0 0.5rem;
    }

    .content p { margin-bottom: 1.2rem; color: #334155; font-size: 1rem; }

    .content ul, .content ol { margin: 0.25rem 0 1.2rem 1.4rem; }
    .content li { margin-bottom: 0.45rem; color: #334155; }

    .content strong { color: var(--dark); font-weight: 600; }

    .content a {
      color: var(--green);
      font-weight: 500;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .content a:hover { color: var(--green-dark); }

    .content blockquote {
      border-left: 4px solid var(--green);
      background: var(--green-pale);
      border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
      padding: 1rem 1.4rem;
      margin: 1.75rem 0;
      font-style: italic;
      color: #475569;
    }
    .content blockquote p { margin: 0; color: #475569; }

    .content hr { border: none; border-top: 1.5px solid var(--border); margin: 2.25rem 0; }

    /* Tables */
    .content .table-wrap, .table-wrap {
      overflow-x: auto;
      margin: 1.75rem 0;
      border-radius: var(--radius-md);
      border: 1px solid var(--border);
      box-shadow: var(--shadow-sm);
    }
    .content table, table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .content thead th, thead th {
      background: var(--gray-light);
      padding: 0.7rem 1rem;
      text-align: left;
      font-weight: 700;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: .05em;
      color: var(--gray);
      border-bottom: 1px solid var(--border);
      font-family: var(--font-display);
    }
    .content td, td { padding: 0.65rem 1rem; border-bottom: 1px solid #f1f5f9; color: #334155; }
    .content tr:last-child td, tr:last-child td { border-bottom: none; }
    .content tr:hover td, tr:hover td { background: var(--green-pale); }

    /* Mention GEO italique fin */
    .content p:last-of-type em, .content em {
      font-size: 0.82rem;
      color: #94a3b8;
    }

    /* Verdict */
    .verdict {
      background: var(--green-pale);
      border: 1.5px solid #86efac;
      border-radius: var(--radius-md);
      padding: 1.5rem 1.75rem;
      margin: 2rem 0;
    }
    .verdict p { margin-bottom: 0.75rem; color: #166534; }
    .verdict p:last-child { margin-bottom: 0; }
    .verdict strong { color: var(--green-dark); }

    /* FAQ */
    .faq-item {
      border-top: 1px solid var(--border);
      padding: 1.1rem 0;
    }
    .faq-item:last-child { border-bottom: 1px solid var(--border); }
    .faq-q { font-weight: 700; font-family: var(--font-display); font-size: 0.92rem; margin-bottom: 0.4rem; color: var(--dark); }
    .faq-a { color: #475569; margin: 0; font-size: 0.9rem; }

    /* CTA buttons */
    .cta-block { display: flex; gap: 0.85rem; flex-wrap: wrap; margin: 2rem 0; }
    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--green);
      color: var(--white) !important;
      font-weight: 700;
      font-size: 0.92rem;
      font-family: var(--font-display);
      padding: 0.75rem 1.5rem;
      border-radius: var(--radius-sm);
      text-decoration: none !important;
      transition: background .15s, transform .1s, box-shadow .15s;
      box-shadow: 0 2px 8px rgba(22,163,74,.25);
    }
    .cta-btn:hover { background: var(--green-dark); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(22,163,74,.35); }
    .cta-btn.secondary {
      background: var(--white);
      color: var(--green) !important;
      border: 1.5px solid var(--green);
      box-shadow: none;
    }
    .cta-btn.secondary:hover { background: var(--green-pale); }

    /* ── CTA BOX ARTICLE ─────────────────────────────────────────────────────── */
    .cta-box {
      position: relative;
      overflow: hidden;
      background: linear-gradient(135deg, var(--dark) 0%, var(--dark-mid) 100%);
      border-radius: var(--radius-lg);
      padding: 2.75rem 2.5rem;
      text-align: center;
      margin: 3.5rem 0 0.5rem;
    }
    .cta-box::before {
      content: '';
      position: absolute;
      top: -60px; right: -60px;
      width: 180px; height: 180px;
      background: var(--green);
      border-radius: 50%;
      opacity: 0.08;
    }
    .cta-box::after {
      content: '';
      position: absolute;
      bottom: -40px; left: -40px;
      width: 120px; height: 120px;
      background: white;
      border-radius: 50%;
      opacity: 0.04;
    }
    .cta-box h3 {
      font-size: 1.3rem;
      color: white;
      margin-bottom: 0.6rem;
      position: relative;
    }
    .cta-box p {
      color: rgba(255,255,255,.7);
      font-size: 0.95rem;
      margin-bottom: 1.5rem;
      position: relative;
    }
    .cta-box a {
      display: inline-block;
      background: var(--green);
      color: var(--white) !important;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1rem;
      padding: 0.85rem 2.25rem;
      border-radius: var(--radius-sm);
      position: relative;
      transition: background .2s, transform .15s;
      text-decoration: none !important;
    }
    .cta-box a:hover { background: var(--green-dark); transform: translateY(-1px); }

    /* ── FOOTER ──────────────────────────────────────────────────────────────── */
    .site-footer {
      background: var(--dark);
      color: rgba(255,255,255,.4);
      padding: 1.75rem 5%;
      text-align: center;
      font-size: 0.78rem;
      flex-shrink: 0;
      line-height: 1.8;
    }
    .site-footer a { color: rgba(255,255,255,.55); }
    .site-footer a:hover { color: #4ade80; text-decoration: underline; }

    /* ── RESPONSIVE ──────────────────────────────────────────────────────────── */
    @media (max-width: 640px) {
      .site-header { padding: 0 4%; }
      .hero { padding: 3.5rem 4% 3rem; }
      main { padding: 2.5rem 4% 4rem; }
      .post-card { padding: 1.25rem 1.35rem; }
      .cta-box { padding: 2rem 1.5rem; }
      .header-nav a:not(.btn-header) { display: none; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <a href="/" class="logo">kdok<em>do</em></a>
    <nav class="header-nav">
      <a href="/blog">Articles</a>
      <a href="/a-propos">À propos</a>
    </nav>
  </header>
  <div class="page-wrap">
    <slot />
  </div>
  <footer class="site-footer">
    <p>
      <a href="/">kdokdo.com</a> — Comparatifs indépendants · Fidélisation &amp; avis Google pour commerces physiques
      &nbsp;·&nbsp; <a href="/a-propos">À propos</a>
    </p>
    <p style="margin-top:0.3rem">Contenu rédigé par des humains · Liens affiliés signalés</p>
  </footer>
</body>
</html>
